{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "route_operator_model_name": {
        "type": "string"
      },
      "route_operator_openai_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "route_operator_openai_api_key",
      "route_operator_model_name"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "prompt_type": "zeroshot_base",
          "num_queries": 2,
          "max_iterations": 10,
          "output_dir": "dump",
          "benchmark_path": "assessment_error_config.json",
          "regenerate_benchmark": true,
          "num_switches": 2,
          "num_hosts_per_subnet": 1
        },
        "participant_roles": {
          "green": "green",
          "purple1": "route_operator"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/netarena-agentbeats/80bf83f885e805d87b7c625d5b9d5c600b1703be/amber/amber-manifest-green.json5",
      "config": {}
    },
    "route_operator": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/netarena-agentbeats-leaderboard/refs/heads/main/amber/amber-manifest-purple.json5",
      "config": {
        "model_name": "${config.route_operator_model_name}",
        "openai_api_key": "${config.route_operator_openai_api_key}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#route_operator.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d48b5-cc1b-7981-ade5-a472b209ef8a",
      "route_operator": "019d48be-bb46-71e0-b1e5-b6a3922f8aae"
    }
  }
}